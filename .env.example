# Gemini API（https://aistudio.google.com/apikey で取得）
GEMINI_API_KEY=your_gemini_api_key

# GitHub Pages URL（設定するとGoogle Chatにブラウザで開くボタンが表示される）
# 例: https://your-username.github.io/your-repo-name
GITHUB_PAGES_URL=

# Reddit API（任意: https://www.reddit.com/prefs/apps で取得）
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USER_AGENT=ITNewsBot/1.0 by YourRedditUsername

# Google Chat Webhook（Googleチャットのスペース設定から取得）
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXXX/messages?key=XXXXX&token=XXXXX
